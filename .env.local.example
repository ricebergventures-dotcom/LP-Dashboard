# ── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Gemini ───────────────────────────────────────────────────────────────────
# Server-side only — never prefix with NEXT_PUBLIC_
# Get from: aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# ── Fund config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_FUND_NAME="Acme Ventures"

# ── Decile Hub ────────────────────────────────────────────────────────────────
# Server-side only — never prefix with NEXT_PUBLIC_
# API token: Settings → Integrations → API Keys in the Decile Hub dashboard
DECILE_HUB_API_TOKEN=your-decile-hub-api-token-here
DECILE_HUB_BASE_URL=https://app.decilehub.com/api
